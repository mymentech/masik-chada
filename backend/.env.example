PORT=5000
MONGO_URI=mongodb://masik_db:27017/masik_db
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRES_IN=7d
JWT_ISSUER=subscription.mymentech.com
JWT_AUDIENCE=masik-chada-api
NODE_ENV=production
CORS_ALLOWED_ORIGINS=https://subscription.mymentech.com
GRAPHQL_INTROSPECTION=false
GRAPHQL_PLAYGROUND=false
GRAPHQL_MAX_QUERY_DEPTH=10
GRAPHQL_MAX_QUERY_LENGTH=10000
GRAPHQL_MAX_VARIABLES_BYTES=20000
AUTH_LOGIN_MAX_ATTEMPTS=10
AUTH_LOGIN_WINDOW_MS=900000
AUTH_LOGIN_LOCK_MS=900000
AUTH_LOGIN_FAILED_DELAY_MS=250
MONTHLY_SNAPSHOT_SCHEDULER_ENABLED=true
